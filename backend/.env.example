# JWT Secret (必须与前端 AUTH_SECRET/JWT_SECRET 相同)
JWT_SECRET="your-jwt-secret-same-as-frontend"

# CORS 允许的前端 URL
FRONTEND_URL="http://localhost:3000"

# Gemini API Key (AI 分析用)
GEMINI_API_KEY="your-gemini-api-key"

# ─── Supabase ─────────────────────────────────────────────────────────────────
# 在 Supabase 项目设置 → API 中获取
# URL: 项目设置 → API → Project URL
# Key: 项目设置 → API → service_role key (SERVER SIDE ONLY, 不要泄露)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
