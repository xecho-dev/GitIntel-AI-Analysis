# ============================================================
# GitIntel 部署环境变量模板
#
# 复制此文件为 deploy.env 并填入真实值：
#   cp deploy.env.example deploy.env
#
# 前端通过 docker-compose.yml 的 build args 注入（BUILD TIME）
# 后端通过 env_file 读取 ./backend/.env
# ============================================================

# ── 公开变量（NEXT_PUBLIC_*）──────────────────────────────────
# 容器网络内：前端访问后端用 backend:8000
NEXT_PUBLIC_API_URL=http://backend:8000

# NextAuth
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_NEXTAUTH_SECRET=请生成随机字符串：openssl rand -base64 32

# Supabase（前端匿名请求用，公开）
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── 运行时变量 ────────────────────────────────────────────────

# 站点对外地址（用于 NextAuth 回调、CORS 等）
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=同上随机字符串

# GitHub OAuth（GitHub 开发者设置 → OAuth Apps → 创建应用后复制）
# 回调地址：https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# GitHub 操作 Token（需要有 repo 权限的 Personal Access Token）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI（Agent 层 LLM 调用）
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Supabase（服务端 admin 操作）
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 前端对外地址（后端 CORS 白名单用）
FRONTEND_URL=http://localhost:3000
