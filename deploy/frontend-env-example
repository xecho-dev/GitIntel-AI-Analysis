# ============================================================
# GitIntel 前端环境变量配置
# ============================================================
# 复制此文件为 frontend-env，填入实际值
# 路径：/opt/gitintel/frontend-env (与后端 .env 分开)
#
# 这些变量在 Docker 构建时被注入到镜像中
# 前端 NEXT_PUBLIC_* 变量必须在这里定义

# ========== API 地址 ==========
# 后端 API 地址（Nginx 代理后访问）
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# ========== Supabase ==========
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ========== NextAuth（如果启用认证） ==========
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate-a-random-secret-here-use-at-least-32-chars
